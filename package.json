{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run clean:next && npx -y node@20 node_modules/next/dist/bin/next dev",
    "dev:node20": "npx -y node@20 node_modules/next/dist/bin/next dev",
    "build": "next build",
    "start": "next start",
    "clean:next": "node -e \"require('node:fs').rmSync('.next',{recursive:true,force:true})\"",
    "lint": "next lint",
    "test": "vitest run",
    "perf:ci": "npm run lint && npm run test && npm run build",
    "perf:lighthouse:pt": "lighthouse http://localhost:3000/pt --only-categories=performance --chrome-flags=\"--headless --no-sandbox\" --output=json --output-path=./external/lighthouse-pt.json",
    "perf:lighthouse:projects": "lighthouse http://localhost:3000/pt/projects --only-categories=performance --chrome-flags=\"--headless --no-sandbox\" --output=json --output-path=./external/lighthouse-projects.json"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.468.0",
    "next": "^13.5.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.5",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.21",
    "eslint": "^8.57.1",
    "eslint-config-next": "^13.5.11",
    "tailwindcss": "^3.4.17",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
